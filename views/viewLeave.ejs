<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <link rel="stylesheet" type="text/css" href="/css/all.css" />
    <link rel="shortcut icon" href="/images/fabicon.jpg">
    <title>HRM</title>
</head>
<body>
<div id="wrapper">
    <div id="header"><strong><a href="/home"><h1>Human Resource Menagement Portal</h1></a></strong>
        <%- include('menu') %>
    </div>
    <div id="main">
        <div class="box">
            <div class="holder">
                <div class="frame">
                    <h1>My Leave History</h1>

                    <table class="altrowstable" id="alternatecolor">
                        <tr>
                            <th>Leave Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Reason</th>
                            <th>Status</th>
                        </tr>
                        <%
                        for (var row in leaves) {
                            var statusLabel = 'Pending';
                            var statusColor = 'orange';
                            if (leaves[row]['status'] === 1) { statusLabel = 'Approved'; statusColor = 'green'; }
                            else if (leaves[row]['status'] === 2) { statusLabel = 'Rejected'; statusColor = 'red'; }
                        %>
                        <tr>
                            <td><%= leaves[row]['leaveType'] %></td>
                            <td><%= leaves[row]['leaveStart'] %></td>
                            <td><%= leaves[row]['leaveEnd'] %></td>
                            <td><%= leaves[row]['description'] %></td>
                            <td style="color:<%= statusColor %>; font-weight:bold;"><%= statusLabel %></td>
                        </tr>
                        <% } %>
                        <% if (leaves.length === 0) { %>
                        <tr><td colspan="5" style="text-align:center;">No leave requests found.</td></tr>
                        <% } %>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>